{
  "version": 2,
  "buildCommand": "npm install --prefix public/admin && npm run build --prefix public/admin",
  "builds": [
    {
      "src": "public/**/*.{js,mjs,css,svg,ico,png,jpg,jpeg,gif,json,woff,woff2,ttf,eot,map,webp}",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "config/**", "services/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Content-Security-Policy": "frame-ancestors 'self' https://zw-express.vercel.app http://localhost:5001;",
        "X-Frame-Options": "ALLOWALL"
      },
      "continue": true
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/admin/dist/assets/$1"
    },
    {
      "src": "/(.+\\.(?:js|mjs|css|svg|ico|png|jpg|jpeg|gif|json|woff2?|ttf|eot|map|webp))(\\?.*)?$",
      "dest": "/public/$1",
      "check": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
